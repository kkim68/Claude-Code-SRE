{
  "compilerOptions": {
    "target": "ES6",
    "module": "commonjs",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,    
    "sourceMap": false,
    "declaration": false
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "dist"]
}
